# ============================================
# Chemicaloop 环境变量配置模板
# ============================================
# 复制此文件为 .env.local 并填写实际值
# .env.local 不会被上传到 GitHub

# ============================================
# 数据库配置（必需）
# ============================================
# PostgreSQL 连接 URL
# 格式：postgresql://用户名:密码@主机:端口/数据库名
PGDATABASE_URL=postgresql://username:password@host:5432/database

# ============================================
# JWT 配置（必需）
# ============================================
# JWT 密钥，用于生成和验证 Token
# 生产环境请使用强密码
JWT_SECRET=your-secure-jwt-secret-key

# ============================================
# 对象存储配置（可选）
# ============================================
# 如果需要图片签名功能，配置以下变量
# 腾讯云 COS 存储桶名称
COZE_BUCKET_NAME=tianzhi-1314611801

# 存储桶地域
COZE_BUCKET_REGION=ap-beijing

# 存储桶 Endpoint
COZE_BUCKET_ENDPOINT_URL=https://cos.ap-beijing.myqcloud.com

# Coze API Key（用于对象存储签名）
COZE_WORKLOAD_IDENTITY_API_KEY=your-coze-api-key

# ============================================
# 后端服务配置（生产环境）
# ============================================
# 后端服务地址
BACKEND_URL=http://localhost:5001

# ============================================
# 其他配置
# ============================================
# UN Comtrade API Key（海关数据）
UN_COMTRADE_API_KEY=your-un-comtrade-api-key
